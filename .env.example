# Argo — configurazione. Copia in .env o esporta come variabili d'ambiente.

# --- rete (regola 4.2: bind sempre 127.0.0.1) ---
ARGO_PORT=8765
# header d'identita' iniettato da Tailscale Serve (l'auth)
ARGO_IDENTITY_HEADER=tailscale-user-login
# SOLO dev locale senza Tailscale davanti. MAI in produzione.
ARGO_DEV_ALLOW_NO_IDENTITY=0

# --- storage ---
ARGO_DB=argo.db
ARGO_ARTIFACTS=artifacts

# --- root dei documenti: casa di default di TUTTI i progetti (§A) ---
# E' SEMPRE una root valida: anche con ARGO_ROOTS vuoto NON e' "tutto negato".
# L'utente non digita mai questo path. Su Linux/CI impostalo a una dir esistente.
ARGO_DOCUMENT_ROOT=C:\Users\miche\Desktop\assistant\document

# --- root del sorgente di Argo, progetto "se stesso" (Addendum) ---
# Vuoto = auto-rilevata dalla posizione del codice (segue l'app se la sposti).
# Sulla macchina dell'utente: C:\Users\miche\Desktop\assistant\PanaAiAssistant
ARGO_SELF_ROOT=
# Guard sui file di sicurezza di Argo dentro il progetto "se stesso": 1 = un OK
# esplicito dal telefono anche se nel perimetro; 0 = mano libera.
ARGO_SELF_PROTECT=1

# --- servizio Documenti: browser file + Obsidian (§B) ---
# cap dell'anteprima inline dei .md (byte); oltre -> solo download.
ARGO_DOCS_MAX_PREVIEW_BYTES=1048576
# deep link Obsidian: nome del vault sul telefono e sottocartella-radice del vault
# dentro document_root ("" = document_root e' la radice del vault).
ARGO_OBSIDIAN_VAULT=
ARGO_OBSIDIAN_VAULT_SUBPATH=

# --- allowlist root EXTRA (regola 4.3), os.pathsep separati. Opzionale: si
# AGGIUNGONO a document_root/self_root (che sono sempre valide). ---
# Windows: separatore ';'  — es: C:\src\repoA;C:\src\repoB
# Linux/mac: separatore ':'
ARGO_ROOTS=

# --- executor locale (GATE 2, §1.9) ---
ARGO_MAX_CONCURRENCY=3
ARGO_MAX_RETRIES=2
ARGO_TASK_TIMEOUT_S=900
OLLAMA_URL=http://localhost:11434
ARGO_OLLAMA_MODEL=qwen3-coder
OLLAMA_CONTEXT_LENGTH=65536

# --- backend abbonamento (planner + escalation): vuoto = default SDK ---
ARGO_SUB_MODEL=

# --- settorializzazione LLM: routing per peso (§A) ---
# Override del profilo hardware (JSON). Vuoto = auto-rilevato (nvidia-smi + Ollama).
# es: {"gpu_name":"RTX 3080 Ti","vram_total_mb":12288,"vram_free_mb":11000,"ram_mb":32768,"cpu_cores":16,"installed_models":["qwen2.5-coder:7b","qwen3-coder","qwen2.5-coder:14b"]}
ARGO_HW_PROFILE=
# Registro dei tier di modello (JSON, lista). Vuoto = template default in config.py.
# es: [{"name":"light","backend":"ollama","model":"qwen2.5-coder:7b","est_vram_mb":6000,"rel_speed":5,"quality":2}, ...]
ARGO_MODEL_TIERS=
# Pazienza globale: patient | balanced | fast. Override per-conversazione/task.
ARGO_PATIENCE=balanced
# Margine di VRAM (MB) da lasciare sempre libero per lo scheduler VRAM-aware.
ARGO_VRAM_HEADROOM_MB=1024
# Cap separato per i task 'frontier' (subscription): non consumano VRAM.
ARGO_SUB_CONCURRENCY=2

# --- approvazioni (regola 4.6: il timeout NEGA) ---
ARGO_APPROVAL_TIMEOUT_S=300

# --- bash allowlist per il PolicyGate (os.pathsep separati) ---
# vuoto = usa il default in config.py (pytest, git status, ruff, ...)
ARGO_BASH_ALLOWLIST=

# --- push VAPID ---
ARGO_VAPID_KEYS=vapid_keys.json
ARGO_VAPID_SUB=mailto:michelepanarotto00@gmail.com
